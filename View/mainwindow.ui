        </spacer>
       </item>
       <item>
        <widget class="QPushButton" name="clearDatabaseButton">
         <property name="minimumSize"><size><width>145</width><height>36</height></size></property>
         <property name="text"><string>Очистить БД</string></property>
         <property name="toolTip"><string>Удалить все записи из базы данных</string></property>
        </widget>
       </item>
       <item>
        <widget class="QPushButton" name="connectButton">
         <property name="minimumSize"><size><width>145</width><height>36</height></size></property>
         <property name="text"><string>Подключиться</string></property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>
   </layout>
  </widget>
 </widget>
