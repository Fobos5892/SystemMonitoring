            <widget class="QDateTimeEdit" name="filterDateTo">
             <property name="calendarPopup"><bool>true</bool></property>
             <property name="displayFormat"><string>dd.MM.yyyy HH:mm</string></property>
            </widget>
           </item>
          </layout>
         </widget>
        </widget>
       </item>
       <item>
        <widget class="QPushButton" name="applyFilterButton">
