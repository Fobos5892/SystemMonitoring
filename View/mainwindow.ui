<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1000</width>
    <height>700</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Мониторинг систем</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* Основной фон – тёмно-синий, чтобы меньше белого */
    QMainWindow {
        background-color: #1e293b;
        font-family: "Segoe UI", Roboto, sans-serif;
        font-size: 13px;
        color: #e2e8f0;
    }

    /* Группы – карточки с тенью, светлый фон */
    QGroupBox {
        background-color: #f1f5f9;
        border: 1px solid #334155;
        border-radius: 10px;
        margin-top: 0.8ex;
        font-weight: 600;
        padding-top: 14px;
        color: #0f172a;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 14px;
        padding: 0 10px;
        background-color: #1e293b;
        color: #f8fafc;
        border-radius: 4px;
        padding: 2px 12px;
        font-size: 13px;
    }

    /* Таблица – тёмная тема для инженерного вида */
    QTableView {
        background-color: #0f172a;
        alternate-background-color: #1e293b;
        gridline-color: #334155;
        border: 1px solid #334155;
        border-radius: 6px;
        selection-background-color: #3b82f6;
        selection-color: #ffffff;
        color: #e2e8f0;
    }
    QHeaderView::section {
        background-color: #1e293b;
        padding: 6px 12px;
        border: none;
        border-bottom: 2px solid #3b82f6;
        font-weight: 600;
        color: #94a3b8;
    }
    QTableView::item {
        padding: 4px 8px;
    }

    /* Поля ввода – тёмные, но читаемые */
    QLabel {
        color: #0f172a;
        font-weight: 600;
    }

    QComboBox, QSpinBox, QDoubleSpinBox, QDateTimeEdit {
        border: 1px solid #475569;
        border-radius: 6px;
        padding: 5px 10px;
        background-color: #0f172a;
        color: #f1f5f9;
        min-height: 30px;
    }
    QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus, QDateTimeEdit:focus {
        border-color: #3b82f6;
        outline: none;
    }
    QComboBox::drop-down {
        border: none;
        background-color: #1e293b;
    }
    QComboBox QAbstractItemView {
        background-color: #0f172a;
        color: #f1f5f9;
        selection-background-color: #3b82f6;
    }

    /* Кнопки – яркие, с эффектами */
    QPushButton {
        border: none;
        border-radius: 6px;
        padding: 6px 16px;
        font-weight: 600;
        font-size: 13px;
        min-height: 30px;
        color: white;
        background-color: #3b82f6;
    }
    QPushButton:hover {
        background-color: #2563eb;
    }
    QPushButton:pressed {
        background-color: #1d4ed8;
    }

    /* Разные кнопки – разный цвет */
    QPushButton#applyFilterButton {
        background-color: #8b5cf6;
    }
    QPushButton#applyFilterButton:hover {
        background-color: #7c3aed;
    }
    QPushButton#connectButton {
        background-color: #10b981;
    }
    QPushButton#connectButton:hover {
        background-color: #059669;
    }
    QPushButton#connectButton[running="true"] {
        background-color: #ef4444;
    }
    QPushButton#connectButton[running="true"]:hover {
        background-color: #dc2626;
    }
    QPushButton#clearDatabaseButton {
        background-color: #f59e0b;
    }
    QPushButton#clearDatabaseButton:hover {
        background-color: #d97706;
    }

    /* Оверлей загрузки */
    QWidget#loadingOverlay {
        background-color: rgba(15, 23, 42, 0.85);
        border-radius: 8px;
    }
    QLabel#loadingTextLabel {
        color: #94a3b8;
        font-size: 15px;
    }
    QLabel#spinnerAnimationLabel {
        color: #3b82f6;
    }
   </string>
  </property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="mainLayout">
    <property name="leftMargin"><number>12</number></property>
    <property name="topMargin"><number>12</number></property>
    <property name="rightMargin"><number>12</number></property>
    <property name="bottomMargin"><number>12</number></property>
    <property name="spacing"><number>10</number></property>

    <!-- 1. Группа таблицы – растягивается через sizePolicy -->
    <item>
     <widget class="QGroupBox" name="groupBoxTable">
      <property name="title">
       <string>Данные</string>
      </property>
      <property name="sizePolicy">
       <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
        <horstretch>1</horstretch>
        <verstretch>1</verstretch>
       </sizepolicy>
      </property>
      <layout class="QVBoxLayout" name="tableGroupLayout">
       <property name="leftMargin"><number>5</number></property>
       <property name="topMargin"><number>5</number></property>
       <property name="rightMargin"><number>5</number></property>
       <property name="bottomMargin"><number>5</number></property>
       <item>
        <widget class="QStackedWidget" name="tableStackedWidget">
         <widget class="QWidget" name="tablePage">
          <layout class="QVBoxLayout" name="tablePageLayout">
           <property name="leftMargin"><number>0</number></property>
           <property name="topMargin"><number>0</number></property>
           <property name="rightMargin"><number>0</number></property>
           <property name="bottomMargin"><number>0</number></property>
           <item>
            <widget class="QTableView" name="SystemTableView">
             <property name="sortingEnabled"><bool>true</bool></property>
             <property name="alternatingRowColors"><bool>true</bool></property>
             <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
            </widget>
           </item>
          </layout>
         </widget>
         <widget class="QWidget" name="loadingPage">
          <layout class="QVBoxLayout" name="loadingPageLayout">
           <property name="leftMargin"><number>0</number></property>
           <property name="topMargin"><number>0</number></property>
           <property name="rightMargin"><number>0</number></property>
           <property name="bottomMargin"><number>0</number></property>
           <item>
            <widget class="QWidget" name="loadingOverlay" native="true">
             <property name="visible"><bool>false</bool></property>
             <layout class="QGridLayout" name="overlayLayout">
              <item row="0" column="0">
               <widget class="QWidget" name="loadingCard" native="true">
                <property name="minimumSize"><size><width>260</width><height>120</height></size></property>
                <layout class="QVBoxLayout" name="cardLayout">
                 <item>
                  <widget class="QLabel" name="spinnerAnimationLabel">
                   <property name="alignment"><set>Qt::AlignCenter</set></property>
                   <property name="text"><string>⟳</string></property>
                   <property name="font"><font><pointsize>28</pointsize></font></property>
                  </widget>
                 </item>
                 <item>
                  <widget class="QLabel" name="loadingTextLabel">
                   <property name="text"><string>Загрузка данных...</string></property>
                   <property name="alignment"><set>Qt::AlignCenter</set></property>
                  </widget>
                 </item>
                </layout>
               </widget>
              </item>
             </layout>
            </widget>
           </item>
          </layout>
         </widget>
        </widget>
       </item>
      </layout>
     </widget>
    </item>

    <!-- 2. Группа статистики -->
    <item>
     <widget class="QGroupBox" name="groupBoxStatistics">
      <property name="title">
       <string>Статистика датчиков</string>
      </property>
      <property name="sizePolicy">
       <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
        <horstretch>0</horstretch>
        <verstretch>0</verstretch>
       </sizepolicy>
      </property>
      <layout class="QHBoxLayout" name="statisticsLayout">
       <property name="leftMargin"><number>10</number></property>
       <property name="topMargin"><number>8</number></property>
       <property name="rightMargin"><number>10</number></property>
       <property name="bottomMargin"><number>8</number></property>
       <property name="spacing"><number>24</number></property>
       <item>
        <widget class="QLabel" name="statsConnectedLabel">
         <property name="text"><string>Активных датчиков(за 10 минут): —</string></property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="statsAverageLabel">
         <property name="text"><string>Среднее: —</string></property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="statsMinLabel">
         <property name="text"><string>Минимум: —</string></property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="statsMaxLabel">
         <property name="text"><string>Максимум: —</string></property>
        </widget>
       </item>
       <item>
        <spacer name="statsSpacer">
         <property name="orientation"><enum>Qt::Horizontal</enum></property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>40</width>
           <height>20</height>
          </size>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>
    </item>

    <!-- 3. Группа фильтра -->
    <item>
     <widget class="QGroupBox" name="groupBoxFilter">
      <property name="title">
       <string>Фильтр</string>
      </property>
      <property name="sizePolicy">
       <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
        <horstretch>0</horstretch>
        <verstretch>0</verstretch>
       </sizepolicy>
      </property>
      <layout class="QHBoxLayout" name="filterLayout">
       <property name="leftMargin"><number>10</number></property>
       <property name="topMargin"><number>8</number></property>
       <property name="rightMargin"><number>10</number></property>
       <property name="bottomMargin"><number>8</number></property>
       <property name="spacing"><number>8</number></property>
       <item>
        <widget class="QComboBox" name="filterFieldComboBox">
         <property name="minimumSize"><size><width>160</width><height>36</height></size></property>
         <property name="toolTip"><string>Тип фильтра</string></property>
         <item><property name="text"><string>ID</string></property></item>
         <item><property name="text"><string>Значение</string></property></item>
         <item><property name="text"><string>Дата</string></property></item>
        </widget>
       </item>
       <item>
        <widget class="QStackedWidget" name="filterValueStack">
         <property name="minimumSize"><size><width>520</width><height>36</height></size></property>
         <widget class="QWidget" name="pageIdFilter">
          <layout class="QHBoxLayout" name="pageIdLayout">
           <property name="leftMargin"><number>0</number></property>
           <property name="topMargin"><number>0</number></property>
           <property name="rightMargin"><number>0</number></property>
           <property name="bottomMargin"><number>0</number></property>
           <item>
            <widget class="QLabel" name="filterIdLabel">
             <property name="text"><string>ID:</string></property>
            </widget>
           </item>
           <item>
            <widget class="QSpinBox" name="filterSpinBox">
             <property name="minimum"><number>0</number></property>
             <property name="maximum"><number>999999</number></property>
            </widget>
           </item>
          </layout>
         </widget>
         <widget class="QWidget" name="pageValueFilter">
          <layout class="QHBoxLayout" name="pageValueLayout">
           <property name="leftMargin"><number>0</number></property>
           <property name="topMargin"><number>0</number></property>
           <property name="rightMargin"><number>0</number></property>
           <property name="bottomMargin"><number>0</number></property>
           <item>
            <widget class="QLabel" name="filterValueLabel">
             <property name="text"><string>Значение:</string></property>
            </widget>
           </item>
           <item>
            <widget class="QComboBox" name="filterValueOperationComboBox">
             <property name="minimumSize"><size><width>110</width><height>0</height></size></property>
             <item><property name="text"><string>равно</string></property></item>
             <item><property name="text"><string>более</string></property></item>
             <item><property name="text"><string>менее</string></property></item>
            </widget>
           </item>
           <item>
            <widget class="QDoubleSpinBox" name="filterDoubleSpinBox">
             <property name="minimumSize"><size><width>120</width><height>0</height></size></property>
             <property name="decimals"><number>2</number></property>
             <property name="minimum"><double>0.000000000000000</double></property>
             <property name="maximum"><double>280.000000000000000</double></property>
             <property name="singleStep"><double>0.010000000000000</double></property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="filterToleranceLabel">
             <property name="text"><string>Погрешность:</string></property>
            </widget>
           </item>
           <item>
            <widget class="QDoubleSpinBox" name="filterToleranceSpinBox">
             <property name="minimumSize"><size><width>110</width><height>0</height></size></property>
             <property name="decimals"><number>4</number></property>
             <property name="minimum"><double>0.000000000000000</double></property>
             <property name="maximum"><double>1.000000000000000</double></property>
             <property name="singleStep"><double>0.010000000000000</double></property>
            </widget>
           </item>
          </layout>
         </widget>
         <widget class="QWidget" name="pageDateRange">
          <layout class="QHBoxLayout" name="pageDateRangeLayout">
           <property name="leftMargin"><number>0</number></property>
           <property name="topMargin"><number>0</number></property>
           <property name="rightMargin"><number>0</number></property>
           <property name="bottomMargin"><number>0</number></property>
           <property name="spacing"><number>6</number></property>
           <item>
            <widget class="QLabel" name="filterDateFromLabel">
             <property name="text"><string>с</string></property>
