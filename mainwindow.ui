    <width>800</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Sensor Telemetry System</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <!-- Главная вертикальная компоновка: таблица сверху, панель снизу -->
   <layout class="QVBoxLayout" name="mainVerticalLayout">
    <property name="spacing">
     <number>10</number>
    </property>
    <property name="leftMargin">
     <number>10</number>
    </property>
    <property name="topMargin">
     <number>10</number>
    </property>
    <property name="rightMargin">
     <number>10</number>
    </property>
    <property name="bottomMargin">
     <number>10</number>
    </property>
    
    <!-- 1. Таблица (Занимает всё свободное место) -->
    <item>
     <widget class="QTableView" name="SystemTableView">
      <property name="sortingEnabled">
       <bool>true</bool>
      </property>
     </widget>
    </item>
    
    <!-- 2. Нижняя панель управления командами -->
    <item>
     <layout class="QHBoxLayout" name="controlPanelLayout">
      <!-- Элемент-пружина (Spacer), сдвигающий кнопки в правый угол -->
      <item>
       <spacer name="horizontalSpacer">
        <property name="orientation">
         <enum>Qt::Horizontal</enum>
        </property>
        <property name="sizeHint" stdset="0">
         <size>
